{
  "name": "agentman",
  "displayName": "AgentMan",
  "version": "1.1.0",
  "description": "Local Ollama-powered AI form filler and browser agent",
  "author": "AgentMan",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test": "vitest run",
    "test:ci": "vitest run --exclude \"**/*.integration.test.ts\"",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/fill-parse.test.ts",
    "test:integration": "vitest run tests/ollama.integration.test.ts tests/ollama-fill.integration.test.ts tests/ollama-expense-repeatable.integration.test.ts tests/ollama-deepseek-text-action.integration.test.ts",
    "test:dom": "vitest run tests/form-engine-repeatable.test.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "idb": "^8.0.2",
    "lucide-react": "^0.475.0",
    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^17.4.4",
    "postcss": "^8.5.2",
    "prettier": "^3.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "manifest": {
    "name": "AgentMan",
    "permissions": [
      "storage",
      "sidePanel",
      "tabs",
      "debugger",
      "declarativeNetRequest"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "commands": {
      "open-sidepanel": {
        "suggested_key": {
          "default": "Alt+Shift+A"
        },
        "description": "Open AgentMan side panel"
      }
    }
  }
}
